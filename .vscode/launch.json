{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Launch strategy runner",
            "type": "debugpy",
            "request": "launch",
            "program": "src/main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "OPENBLAS_NUM_THREADS": "1"
            }
        }
    ]
}